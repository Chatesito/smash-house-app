	<dataset name="rankingDataset" uuid="57afc352-1b83-4faf-92b7-ef851935914b">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="smash_house"/>
		<query language="SQL"><![CDATA[SELECT
    position as "position",
    nickname as "nickname",
    points as "points",
    tournaments_played as "tournamentsPlayed",
    tournaments_won as "tournamentsWon",
    matches_won as "matchesWon",
    matches_lost as "matchesLost",
    main_character as "mainCharacter",
    secondary_character as "secondaryCharacter",
    CASE
        WHEN (matches_won + matches_lost) = 0 THEN 0
        ELSE ROUND((matches_won * 100.0) / (matches_won + matches_lost), 2)
    END as "winRate"
FROM player_rankings
ORDER BY position ASC]]></query>
